{
  "compilerOptions": {
    "types": ["node","mocha"],
    "outDir": "./build",
    "allowJs": true,
    "target": "es6",
    "esModuleInterop": true,
    "module": "CommonJS",
    "sourceMap": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
  },
  "exclude": [
    "test",
    "tests",
    "**/*.test.ts",
    "**/*.spec.ts",
    "node_modules",
    "build",
    "dist"
  ]
}
