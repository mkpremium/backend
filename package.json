{
  "name": "mk-backend",
  "main": "server.js",
  "scripts": {
    "lint": "./scripts/lint.sh",
    "lint:fix": "./scripts/lint.sh --fix",
    "start": "better-npm-run start",
    "pretest": "npm run lint",
    "test": "./scripts/run-test.sh test",
    "test:e2e": "./scripts/run-test.sh test-e2e",
    "start_all": "better-npm-run start:all",
    "prestart_banks": "npm run lint",
    "start_banks": "better-npm-run start_banks",
    "prestart_migration": "npm run lint",
    "build": "scripts/build-without-dependencies.sh",
    "deploy:uat": "scripts/deployment.sh mkpremium-uat",
    "deploy:prod": "scripts/deployment.sh mkpremium-prod",
    "socket": "better-npm-run socket",
    "cronjobs": "better-npm-run cronjobs",
    "seed_all": "better-npm-run seed_all",
    "seed_metadata": "better-npm-run seed_metadata",
    "seed_family": "better-npm-run seed_family",
    "seed_people": "better-npm-run seed_people",
    "seed_denormalize": "better-npm-run seed_denormalize",
    "banks_worker_0": "better-npm-run banks_worker_0",
    "banks_worker_1": "better-npm-run banks_worker_1",
    "migration_worker_0": "better-npm-run migration_worker_0",
    "migration_worker_1": "better-npm-run migration_worker_1"
  },
  "betterScripts": {
    "banks_worker_0": "nodemon $NODE_DEBUG_OPTION src/banks/worker/bank-load.js --exec babel-node",
    "banks_worker_1": "nodemon $NODE_DEBUG_OPTION src/banks/worker/bank-process.js --exec babel-node",
    "migration_worker_0": "nodemon $NODE_DEBUG_OPTION src/migration/workers/cross-csv.js --exec babel-node",
    "migration_worker_1": "nodemon $NODE_DEBUG_OPTION src/migration/workers/seed.js --exec babel-node",
    "start_banks": "nodemon $NODE_DEBUG_OPTION bin/www-bank.js --exec babel-node",
    "start": "nodemon bin/www.js --exec babel-node $NODE_DEBUG_OPTION ",
    "socket": "nodemon bin/socket.js --exec babel-node",
    "deploy": "scripts/deployment.sh",
    "cronjobs": "nodemon bin/cronjobs.js --exec babel-node",
    "start:all": "nf start",
    "seed_all": "node $NODE_DEBUG_OPTION --max-old-space-size=8192 migrations",
    "seed_family": "babel-node $NODE_DEBUG_OPTION migrations/seed_family.js",
    "seed_people": "babel-node $NODE_DEBUG_OPTION migrations/seed_people.js",
    "seed_denormalize": "babel-node $NODE_DEBUG_OPTION migrations/seed_denormalize.js",
    "seed_metadata": "babel-node $NODE_DEBUG_OPTION migrations/seed_meta.js"
  },
  "dependencies": {
    "@babel/polyfill": "^7.7.0",
    "aws-sdk": "^2.704.0",
    "axios": "^0.18.1",
    "bcrypt": "^2.0.1",
    "bluebird": "^3.5.1",
    "body-parser": "^1.15.0",
    "camaro": "^3.0.16",
    "cli-table": "^0.3.1",
    "commander": "^2.19.0",
    "compose-middleware": "^4.0.0",
    "cors": "^2.8.4",
    "couchbase": "^2.6.10",
    "cron": "^1.3.0",
    "debug": "^3.1.0",
    "dotenv": "^5.0.1",
    "express": "^4.16.3",
    "express-jwt": "^5.3.1",
    "express-jwt-permissions": "^1.1.0",
    "express-promise-wrap": "^0.2.2",
    "firebase-admin": "^5.12.0",
    "fs-extra": "^5.0.0",
    "geolib": "^2.0.24",
    "jsonwebtoken": "^8.2.1",
    "lodash": "^4.17.15",
    "mime-types": "^2.1.19",
    "moment-range": "^4.0.1",
    "moment-timezone": "^0.5.16",
    "morgan": "^1.9.1",
    "morgan-body": "^2.4.0",
    "multer": "^1.3.0",
    "node-gyp": "^3.8.0",
    "nodemailer": "^4.6.4",
    "request": "^2.88.0",
    "request-promise": "^4.2.2",
    "socket.io": "^2.1.0",
    "socket.io-client": "^2.1.0",
    "squel": "^5.12.1",
    "tcomb": "^3.2.25",
    "uuid": "^3.2.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.7.7",
    "@babel/core": "^7.7.7",
    "@babel/node": "^7.7.7",
    "@babel/preset-env": "^7.7.7",
    "@babel/register": "^7.7.7",
    "better-npm-run": "^0.1.0",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chance": "^1.0.16",
    "eslint": "^4.19.1",
    "eslint-config-standard": "^11.0.0",
    "eslint-plugin-babel": "^4.1.2",
    "eslint-plugin-import": "^2.11.0",
    "eslint-plugin-node": "^6.0.1",
    "eslint-plugin-promise": "^3.7.0",
    "eslint-plugin-standard": "^3.1.0",
    "foreman": "^2.0.0",
    "heapdump": "^0.3.9",
    "minimist": "^1.2.0",
    "mocha": "^7.1.0",
    "mocha-circleci-reporter": "0.0.2",
    "nodemon": "^1.17.4",
    "sinon": "^9.0.1",
    "sinon-chai": "^3.5.0",
    "supertest": "^4.0.2"
  },
  "private": true
}
