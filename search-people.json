{
  "name": "search-people",
  "type": "fulltext-index",
  "params": {
    "doc_config": {
      "mode": "type_field",
      "type_field": "_documentType"
    },
    "mapping": {
      "default_analyzer": "standard",
      "default_datetime_parser": "dateTimeOptional",
      "default_field": "_all",
      "default_mapping": {
        "dynamic": true,
        "enabled": false
      },
      "default_type": "_default",
      "index_dynamic": true,
      "store_dynamic": false,
      "types": {
        "person": {
          "default_analyzer": "ar",
          "dynamic": true,
          "enabled": true,
          "properties": {
            "contacts": {
              "dynamic": true,
              "enabled": true,
              "properties": {
                "value": {
                  "enabled": true,
                  "dynamic": false,
                  "fields": [
                    {
                      "analyzer": "",
                      "include_in_all": true,
                      "include_term_vectors": true,
                      "index": true,
                      "name": "contact",
                      "store": true,
                      "type": "text"
                    }
                  ]
                }
              }
            },
            "documentNumber": {
              "enabled": true,
              "dynamic": false,
              "fields": [
                {
                  "include_in_all": true,
                  "include_term_vectors": true,
                  "index": true,
                  "name": "document",
                  "store": true,
                  "type": "text"
                }
              ]
            },
            "name": {
              "enabled": true,
              "dynamic": false,
              "fields": [
                {
                  "include_in_all": true,
                  "include_term_vectors": true,
                  "index": true,
                  "name": "name",
                  "store": true,
                  "type": "text"
                }
              ]
            }
          }
        }
      }
    },
    "store": {
      "kvStoreName": "mossStore"
    }
  },
  "sourceType": "couchbase",
  "sourceName": "mkpremium",
  "sourceParams": {},
  "planParams": {
    "maxPartitionsPerPIndex": 171,
    "numReplicas": 0
  }
}

