		{
			"name": "Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"id": "e8addef2-30b2-4456-ba50-56f99111c1a7",
						"exec": [
							"pm.test(\"ValidResponse\", function() {",
							"    pm.response.to.have.status(200);",
							"    pm.response.to.have.jsonBody(\"token\");",
							"})",
							"",
							"const responseData = pm.response.json();",
							"",
							"pm.collectionVariables.set(\"accessToken\", responseData.token);",
							""
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
